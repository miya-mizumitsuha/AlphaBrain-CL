# ============================================================================
# AlphaBrain 环境变量模板
# ----------------------------------------------------------------------------
# 复制为 .env 后按本机路径填写。.env 已在 .gitignore，不会被提交。
#   cp .env.example .env
#   vim .env
# 启动脚本（scripts/run_*.sh）执行前会自动 source .env，
# OmegaConf 在 yaml 中通过 ${oc.env:VAR} 引用这些变量。
# ============================================================================

# ── 训练 / 微调必需 ─────────────────────────────────────────────────────
# 预训练 VLM 根目录（含 Qwen2.5-VL-3B-Instruct/、Llama-3.2-11B-Vision-Instruct/、
# paligemma-3b-pt-224/ 等子目录）
PRETRAINED_MODELS_DIR=/path/to/pretrained_models

# LeRobot 格式 LIBERO 数据根目录
# 子目录: libero_{spatial,object,goal,10}_no_noops_1.0.0_lerobot/
# 由 benchmarks/LIBERO/data_preparation.sh 准备。
# - LEROBOT_LIBERO_DATA_DIR: configs/continual_learning/* 引用
# - LIBERO_DATA_ROOT       : configs/finetune_config.yaml 等 base VLA 配置引用
# 两者格式相同，可指向同一目录。
LEROBOT_LIBERO_DATA_DIR=/path/to/LEROBOT_LIBERO_DATA
LIBERO_DATA_ROOT=/path/to/LEROBOT_LIBERO_DATA

# ── LIBERO 评估必需 ─────────────────────────────────────────────────────
# LIBERO 仿真源码根目录
LIBERO_HOME=/path/to/LIBERO

# 评估客户端 Python 解释器（独立 conda env，含 LIBERO 仿真依赖）
LIBERO_PYTHON=/path/to/anaconda3/envs/AlphaBrain/bin/python

# ── 可选：W&B 追踪 ─────────────────────────────────────────────────────
# WANDB_API_KEY=your_wandb_api_key
# WANDB_BASE_URL=https://api.wandb.ai

# ── 可选：其他 benchmark 评估 Python ───────────────────────────────────
# ROBOCASA_TABLETOP_PYTHON=/path/to/anaconda3/envs/robocasa2/bin/python
# ROBOCASA365_PYTHON=/path/to/anaconda3/envs/robocasa/bin/python
